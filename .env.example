# Database (SQLite - no installation needed!)
DATABASE_URL=file:./data/zenith.db

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=7d

# CORS (frontend origin for API and WebSocket)
WS_CORS_ORIGIN=http://localhost:3000

# API
PORT=4000

# Uploads (local storage)
UPLOAD_PATH=./uploads
UPLOAD_BASE_URL=http://localhost:4000/uploads

# Frontend (set in apps/web when building)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
