{
  "name": "zenith",
  "private": true,
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev --workspace api",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run prisma:generate --workspace api",
    "db:migrate": "npm run prisma:migrate --workspace api",
    "db:push": "npm run prisma:push --workspace api",
    "db:studio": "npm run prisma:studio --workspace api",
    "launch": "node scripts/launch.js",
    "build:exe": "pkg scripts/launch.js --targets node18-win-x64 --output zenith.exe"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
