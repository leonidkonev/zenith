{
  "name": "zenith",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm run -r build",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:push": "pnpm --filter api exec prisma db push",
    "db:studio": "pnpm --filter api exec prisma studio",
    "launch": "node scripts/launch.js",
    "build:exe": "pkg scripts/launch.js --targets node18-win-x64 --output zenith.exe"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.15.0"
}
